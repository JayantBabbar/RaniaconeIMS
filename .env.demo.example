# Demo mode — set these in Vercel project env to ship a backend-less build.
# When NEXT_PUBLIC_DEMO_MODE=true, all API calls are handled by an in-memory
# axios adapter seeded with fixture data from src/lib/demo/.

NEXT_PUBLIC_DEMO_MODE=true

# These values are unused in demo mode but still referenced at build time —
# give them any syntactically valid URL.
NEXT_PUBLIC_AUTH_API_URL=https://demo.invalid/api/v1
NEXT_PUBLIC_INVENTORY_API_URL=https://demo.invalid/api/v1

# ── Hardcoded demo logins (all use password "demo123") ──────────────
# superadmin@demo.com   — platform super admin, can impersonate tenants
# admin@demo.com        — tenant admin with full inventory permissions
# ops@demo.com          — operator: read + movements/documents write
# viewer@demo.com       — read-only
